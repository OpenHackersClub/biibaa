---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const briefs = await getCollection("briefs");
  return briefs.map((brief) => ({
    params: { id: brief.id.replace(/\.md$/, "") },
    props: { brief },
  }));
}

const { brief } = Astro.props;
const { Content } = await render(brief);
const fm = brief.data;
const score = fm.score;
const repo = fm.project.repo_url;
const npmUrl =
  fm.project.ecosystem === "npm" && fm.project.name
    ? `https://www.npmjs.com/package/${fm.project.name}`
    : null;
---

<Base title={`${fm.title} — biibaa`} description={`Improvement brief for ${fm.title}`}>
  <span slot="header-right">
    <a href="/" class="text-[var(--color-muted)] hover:text-[var(--color-text)]">← all briefs</a>
  </span>

  <div class="grid grid-cols-1 md:grid-cols-[1fr_280px] gap-5">
    <article class="prose-brief bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-7 shadow-[0_12px_32px_-16px_rgb(0_0_0/0.5)]">
      <Content />
    </article>

    <aside class="flex flex-col gap-3">
      <div class="filter-card">
        <div class="text-xs uppercase tracking-wider text-[var(--color-muted)] mb-2">Score</div>
        <div class="flex items-baseline gap-3">
          <span
            class:list={[
              "score-chip text-base px-3 py-1",
              score.total >= 70 ? "high" : score.total >= 50 ? "mid" : "low",
            ]}
          >
            {score.total.toFixed(1)}
          </span>
          <span class="text-xs text-[var(--color-muted)]">total</span>
        </div>
        <dl class="grid grid-cols-2 gap-x-3 gap-y-1 text-sm mt-3">
          <dt class="text-[var(--color-muted)]">Impact</dt><dd class="text-right mono">{score.impact.toFixed(1)}</dd>
          <dt class="text-[var(--color-muted)]">Effort</dt><dd class="text-right mono">{score.effort.toFixed(1)}</dd>
          <dt class="text-[var(--color-muted)]">Confidence</dt><dd class="text-right mono">{score.confidence}</dd>
        </dl>
      </div>

      <div class="filter-card">
        <div class="text-xs uppercase tracking-wider text-[var(--color-muted)] mb-2">Project</div>
        <div class="text-sm space-y-1">
          <div><span class="text-[var(--color-muted)]">Eco</span> · <span class="mono">{fm.project.ecosystem}</span></div>
          {repo && (
            <div>
              <a href={repo} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-[var(--color-accent)] mono text-xs">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
                </svg>
                {repo.replace(/^https?:\/\//, "").replace(/^github\.com\//, "")}
              </a>
            </div>
          )}
          {npmUrl && (
            <div>
              <a href={npmUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-[var(--color-accent)] mono text-xs">
                <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                  <rect width="16" height="16" rx="1" fill="#cb3837"/>
                  <path d="M3 4h10v8H8.5V6H7v6H3V4z" fill="#fff"/>
                </svg>
                npmjs.com/package/{fm.project.name}
              </a>
            </div>
          )}
          {fm.project.downloads_weekly !== null && (
            <div>
              <span class="text-[var(--color-muted)]">Weekly DL</span> ·
              <span class="mono"> {fm.project.downloads_weekly.toLocaleString()}</span>
            </div>
          )}
          {fm.project.archived && (
            <div class="text-amber-400">archived</div>
          )}
        </div>
      </div>

      {fm.maintainer_activity && (
        <div class="filter-card">
          <div class="text-xs uppercase tracking-wider text-[var(--color-muted)] mb-2">Maintainer activity</div>
          <div class="text-sm">{fm.maintainer_activity.label}</div>
          {fm.maintainer_activity.last_pr_merged_at && (
            <div class="text-xs text-[var(--color-muted)] mono mt-1">
              {fm.maintainer_activity.last_pr_merged_at.split("T")[0]}
            </div>
          )}
        </div>
      )}

      {fm.benchmarks && (
        <div class="filter-card">
          <div class="text-xs uppercase tracking-wider text-[var(--color-muted)] mb-2">Benchmarks</div>
          <div class="text-sm">{fm.benchmarks.has ? "yes" : "no"}</div>
          {fm.benchmarks.signal && (
            <div class="text-xs text-[var(--color-muted)] mono mt-1">{fm.benchmarks.signal}</div>
          )}
        </div>
      )}

      {fm.tags.length > 0 && (
        <div class="filter-card">
          <div class="text-xs uppercase tracking-wider text-[var(--color-muted)] mb-2">Tags</div>
          <div class="flex flex-wrap gap-1">
            {fm.tags.map((t) => <span class="tag-chip">{t}</span>)}
          </div>
        </div>
      )}
    </aside>
  </div>
</Base>
